# Copy to `.env` in the repo root and fill in values.
# The agent harness loads `.env` automatically (does not override vars already set in your shell).

# --- OpenAI (official API) — default harness targets this ---
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-proj-your-key-here
# Use an id your key can access: gpt-4o-mini, gpt-4o, gpt-4-turbo (bare `gpt-4` often returns "invalid model ID").
HARNESS_MODEL=gpt-4o-mini

# --- LM Studio / Ollama / local OpenAI-compatible ---
# Do NOT use sk-proj-* keys against localhost — LM Studio expects its own dev key.
# Comment out the OpenAI block above, then use e.g.:
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1
# OPENAI_API_KEY=lm-studio   # or the key shown in LM Studio settings
# HARNESS_MODEL=qwen/qwen3-vl-4b

# Optional: full POST URL for chat completions (overrides OPENAI_BASE_URL joining).
# OPENAI_COMPLETIONS_URL=

# Optional: set to 1 if your gateway only exposes /chat/completions (no /v1 segment).
# HARNESS_OPENAI_NO_V1=0

# --- Harness mode ---
# live  = call the LLM (default if unset)
# replay = use recordings/*.jsonl (CI, no API)
# record = live run + write new JSONL transcripts
# HARNESS_MODE=live

# Optional: print resolved chat URL to stderr (1 = on).
# HARNESS_DEBUG=0
